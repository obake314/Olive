{
  "expo": {
    "name": "Olive",
    "slug": "olive",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#5c724a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.olive.mealplanner"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5c724a"
      },
      "package": "com.olive.mealplanner"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "baseUrl": "/Olive"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
